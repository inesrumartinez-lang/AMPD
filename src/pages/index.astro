---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="eyebrow">Comunidad de Madrid</span>

          <h1 class="hero-title">
            Asociación<br/>
            Madrileña de<br/>
            <span class="hero-emphasis">Psicología<br/>del Deporte</span>.
          </h1>

          <p class="hero-lead">
            Agrupamos a profesionales, estudiantes y deportistas comprometidos
            con el desarrollo de la disciplina en Madrid.
          </p>

          <div class="hero-actions">
            <a href="/hazte-socio" class="btn btn-primary">
              Hazte socio
              <span class="arrow">→</span>
            </a>
            <a href="/informacion" class="btn btn-ghost">
              Información de interés
            </a>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="hero-card hero-card--1">
            <span class="num">01</span>
            <span class="label">Promover</span>
          </div>
          <div class="hero-card hero-card--2">
            <span class="num">02</span>
            <span class="label">Conectar</span>
          </div>
          <div class="hero-card hero-card--3">
            <span class="num">03</span>
            <span class="label">Formar</span>
          </div>
          <div class="hero-pulse"></div>
        </div>
      </div>

      <!-- Marquee -->
      <div class="marquee">
        <div class="marquee-track">
          <span>Rendimiento</span><span>•</span>
          <span>Investigación</span><span>•</span>
          <span>Práctica aplicada</span><span>•</span>
          <span>Comunidad</span><span>•</span>
          <span>Formación</span><span>•</span>
          <span>Salud mental</span><span>•</span>
          <span>Rendimiento</span><span>•</span>
          <span>Investigación</span><span>•</span>
          <span>Práctica aplicada</span><span>•</span>
          <span>Comunidad</span><span>•</span>
          <span>Formación</span><span>•</span>
          <span>Salud mental</span><span>•</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DESTACADO ASAMBLEA -->
  <section class="highlight-section">
    <div class="container">
      <div class="highlight-card reveal">
        <div class="highlight-tag">Asamblea General Extraordinaria</div>
        <h2>Convocatoria<br/>Asamblea General<br/><em>Extraordinaria</em></h2>
        <div class="highlight-details">
          <div>
            <span class="detail-label">Fecha</span>
            <span class="detail-value">Miércoles, 25 de febrero de 2026</span>
          </div>
          <div>
            <span class="detail-label">Forma</span>
            <span class="detail-value">Videollamada · Google Meet</span>
          </div>
          <div>
            <span class="detail-label">Hora</span>
            <span class="detail-value">20:30 (Madrid)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VENTAJAS DE SER SOCIO -->
  <section class="benefits-home">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Ventajas de ser socio</span>
        <h2>¿Qué te ofrece<br/>asociarte?</h2>
      </div>

      <div class="benefits-grid">
        <article class="benefit-card reveal">
          <span class="num">01</span>
          <p>Asistencia gratuita a jornadas sobre psicología del deporte con presencia de deportistas de élite y psicólogos que trabajan con ellos.</p>
        </article>
        <article class="benefit-card reveal">
          <span class="num">02</span>
          <p>Intercambio de información con otros psicólogos a través de diferentes vías: Instagram, Facebook, WhatsApp, Email.</p>
        </article>
        <article class="benefit-card reveal">
          <span class="num">03</span>
          <p>Pertenencia a una lista de correo para recibir y difundir información sobre jornadas, eventos, cursos, etc. sobre psicología del deporte.</p>
        </article>
        <article class="benefit-card reveal">
          <span class="num">04</span>
          <p>Descuentos en las cuotas de los congresos organizados por la FEPD (Federación Española de Psicología del Deporte).</p>
        </article>
      </div>

      <a href="/hazte-socio" class="link-arrow reveal">
        Ver cuotas y cómo inscribirse →
      </a>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-final">
    <div class="container">
      <div class="cta-box reveal">
        <span class="eyebrow" style="color: var(--flame);">Únete</span>
        <h2>
          Forma parte de la<br/>
          <span class="cta-emphasis">comunidad de psicología<br/>del deporte</span><br/>
          en Madrid.
        </h2>
        <p>50€ anuales para profesionales · 25€ el primer año para estudiantes. Pago domiciliado.</p>
        <a href="/hazte-socio" class="btn btn-primary">
          Quiero ser socio
          <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Activar flotación continua de las tarjetas del hero tras la animación de entrada
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.hero-card').forEach(card => card.classList.add('float'));
    }, 1600);
  });
</script>

<style>
  .hero {
    padding-top: 4rem;
    padding-bottom: 0;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 70vh;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
  .hero-content .eyebrow { margin-bottom: 1.5rem; color: var(--ink-soft); }
  .hero-title {
    margin-bottom: 2rem;
    animation: heroIn 1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-emphasis {
    font-style: italic;
    font-weight: 400;
    color: var(--flame);
    position: relative;
    display: inline-block;
  }
  .hero-emphasis::after {
    content: '';
    position: absolute;
    bottom: 0.05em;
    left: 0; right: 0;
    height: 0.06em;
    background: var(--flame);
    transform: scaleX(0);
    transform-origin: left;
    animation: underline 1s 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes underline { to { transform: scaleX(1); } }
  .hero-lead {
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 42ch;
    margin-bottom: 2.5rem;
    animation: heroIn 1s 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: heroIn 1s 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }
  .hero-visual {
    position: relative;
    min-height: 380px;
    max-width: 420px;
    margin-left: auto;
    padding: 1rem;
  }
  .hero-card {
    position: absolute;
    background: var(--paper-pure);
    border: 1.5px solid var(--ink);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 6px 6px 0 var(--ink);
    animation: floatIn 1s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
    min-width: 140px;
  }
  .hero-card .num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--flame);
    letter-spacing: 0.1em;
  }
  .hero-card .label {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
  }
  .hero-card--1 {
    top: 5%; left: 5%; transform: rotate(-3deg); animation-delay: 0.6s;
  }
  .hero-card--1.float { animation: floatLoop1 6s ease-in-out infinite; }
  .hero-card--2 {
    top: 38%; right: 5%; transform: rotate(2deg);
    background: var(--ink); color: var(--paper);
    box-shadow: 6px 6px 0 var(--flame);
    animation-delay: 0.8s;
  }
  .hero-card--2.float { animation: floatLoop2 7s ease-in-out infinite; }
  .hero-card--2 .num { color: var(--flame); }
  .hero-card--3 {
    bottom: 5%; left: 20%; transform: rotate(-2deg); animation-delay: 1s;
  }
  .hero-card--3.float { animation: floatLoop3 5.5s ease-in-out infinite; }
  .hero-pulse {
    position: absolute;
    bottom: 32%; right: 32%;
    width: 70px; height: 70px;
    border-radius: 50%;
    background: var(--flame);
    z-index: -1;
    animation: pulse 3s ease-in-out infinite, floatIn 1s 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }
  @keyframes floatIn { from { opacity: 0; transform: translateY(40px) rotate(0deg); } }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.3; }
  }
  @keyframes floatLoop1 {
    0%, 100% { transform: rotate(-3deg) translateY(0); }
    50% { transform: rotate(-5deg) translateY(-14px); }
  }
  @keyframes floatLoop2 {
    0%, 100% { transform: rotate(2deg) translateY(0); }
    50% { transform: rotate(4deg) translateY(-18px); }
  }
  @keyframes floatLoop3 {
    0%, 100% { transform: rotate(-2deg) translateY(0); }
    50% { transform: rotate(-4deg) translateY(-12px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-card.float { animation: none !important; }
  }
  @media (max-width: 900px) {
    .hero-visual { max-width: 360px; margin: 0 auto; }
  }

  .marquee {
    margin-top: 6rem;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    padding: 1.5rem 0;
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    gap: 2.5rem;
    white-space: nowrap;
    animation: scroll 20s linear infinite;
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 800;
    font-style: italic;
  }
  .marquee-track span:nth-child(odd) { color: var(--ink); }
  .marquee-track span:nth-child(even) { color: var(--flame); font-style: normal; }
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* HIGHLIGHT */
  .highlight-section { padding: 5rem 0 3rem; }
  .highlight-card {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(2.5rem, 5vw, 4rem);
    position: relative;
    overflow: hidden;
  }
  .highlight-card::before {
    content: '';
    position: absolute;
    top: -50%; right: -10%;
    width: 350px; height: 350px;
    background: radial-gradient(circle, var(--flame) 0%, transparent 70%);
    opacity: 0.3;
    border-radius: 50%;
  }
  .highlight-tag {
    display: inline-block;
    background: var(--flame);
    color: var(--paper);
    padding: 0.4rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
    position: relative;
  }
  .highlight-card h2 {
    margin-bottom: 2.5rem;
    position: relative;
  }
  .highlight-card h2 em {
    color: var(--flame);
    font-style: italic;
    font-weight: 400;
  }
  .highlight-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    border-top: 1px solid rgba(245, 241, 232, 0.2);
    padding-top: 2rem;
    position: relative;
  }
  @media (max-width: 700px) {
    .highlight-details { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  .detail-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--flame);
    margin-bottom: 0.5rem;
  }
  .detail-value {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
  }

  /* BENEFITS HOME */
  .benefits-home { padding-top: 5rem; }
  .section-header { margin-bottom: 4rem; }
  .section-header .eyebrow { margin-bottom: 1rem; }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 700px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }
  .benefit-card {
    padding: 2.5rem 2rem;
    background: var(--paper-pure);
    border: 1.5px solid var(--ink);
    transition: all 0.3s ease;
  }
  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: 8px 8px 0 var(--ink);
    background: var(--ink);
    color: var(--paper);
  }
  .benefit-card .num {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--flame);
    margin-bottom: 1.5rem;
  }
  .benefit-card p { line-height: 1.6; font-size: 1rem; }

  .link-arrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink);
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 0.25rem;
    transition: all 0.2s ease;
  }
  .link-arrow:hover { color: var(--flame); border-color: var(--flame); }

  /* NEWS HOME */
  .news-home { padding-top: 5rem; }
  .agenda-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2rem;
    align-items: end;
    margin-bottom: 3rem;
  }
  @media (max-width: 700px) {
    .agenda-header { grid-template-columns: 1fr; }
  }
  .agenda-header h2 em { font-style: italic; font-weight: 400; color: var(--flame); }
  .btn-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink);
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 0.25rem;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn-link:hover { color: var(--flame); border-color: var(--flame); }

  .news-list { border-top: 1.5px solid var(--ink); }
  .news-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1.5px solid var(--ink);
    transition: padding 0.3s ease;
  }
  .news-item:hover { padding-left: 1rem; }
  @media (max-width: 600px) {
    .news-item { grid-template-columns: 1fr; gap: 1rem; }
  }
  .news-date-tag {
    background: var(--flame);
    color: var(--paper);
    padding: 1rem 1.25rem;
    text-align: center;
    min-width: 100px;
    align-self: start;
  }
  .news-date-tag .day {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }
  .news-date-tag .month {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    margin-top: 0.25rem;
    display: block;
  }
  .news-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--flame);
    margin-bottom: 0.5rem;
    display: inline-block;
  }
  .news-info h3 {
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    margin-bottom: 0.75rem;
  }
  .news-info p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* CTA FINAL */
  .cta-final { padding-bottom: 6rem; padding-top: 3rem; }
  .cta-box {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(3rem, 8vw, 6rem) clamp(2rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .cta-box::before {
    content: '';
    position: absolute;
    top: -50%; right: -10%;
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--flame) 0%, transparent 70%);
    opacity: 0.4;
    border-radius: 50%;
  }
  .cta-box > * { position: relative; z-index: 2; }
  .cta-box h2 { margin: 1.5rem 0 1.5rem; max-width: 18ch; }
  .cta-emphasis { color: var(--flame); font-style: italic; font-weight: 400; }
  .cta-box p {
    max-width: 50ch;
    color: rgba(245, 241, 232, 0.8);
    font-size: 1.05rem;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }
</style>
